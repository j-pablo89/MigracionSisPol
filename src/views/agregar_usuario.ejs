<%- include ('partials/_header2')%>

<div class="container mainSection mb-5" id="main-container" data-page="agregar_usuario">
    
    <form class="row g-3 bg-light fw-bold mt-5 border border-5 border-primary" action="/guardar_usuario" method="POST">
        <div class="modal-header d-flex justify-content-center align-self-center m-0 p-0 bg-secondary">
            <h3 class="fw-bold text-white my-3">CREAR USUARIO</h3>
        </div>
        <h5 class="fw-bold text-black">Datos Personales</h5>
        <div class="col-md-4">
          <label for="Dni" class="form-label">Nro Documento</label>
          <input type="text" class="form-control" name="Dni" id="Dni" maxlength="8" inputmode="numeric" pattern="\d{8}" title="El DNI debe contener exactamente 8 números" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
        </div>
        <div class="clear-fix"></div>
        <div class="col-md-6">
          <label for="apellido" class="form-label">Apellido</label>
          <input type="text" class="form-control" name="Apellido" id="Apellido" title="Ingrese su apellido" required>
        </div>
        <div class="col-md-6">
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" class="form-control" name="Nombre" id="Nombre" title="Ingrese su nombre" required>
        </div>
        <div class="col-md-6">
          <label for="email" class="form-label">Email</label>
          <input type="email" class="form-control" name="Email" id="Email" title="Ingrese su email" required>
        </div>
        <div class="col-md-6 mb-3">
          <label for="telefono" class="form-label">Telefono</label>
          <input type="text" class="form-control" name="Telefono" id="Telefono" maxlength="10"  inputmode="numeric" pattern="[0-9]*" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
        </div>
        <div class="col-md-6 mb-3">
          <label for="ubicacion" class="form-label">Ubicacion de Trabajo</label>
          <input type="text" class="form-control" name="Ubicacion" id="Ubicacion" required>
        </div>
        <div class="col-md-6 mb-3">
          <label for="funcion" class="form-label">Funcion que cumple</label>
          <input type="text" class="form-control" name="Funcion" id="Funcion" required>
        </div>
        <h5 class="fw-bold text-black">Datos de Acceso</h5>
        <div class="col-md-6">
          <label for="usuario" class="form-label">Usuario</label>
          <input type="text" class="form-control" name="Usuario" id="Usuario" required readonly>
        </div>
        <div class="clear-fix"></div>
        <div class="col-md-6">
          <label for="contrasenia" class="form-label">Contraseña</label>
          <input type="password" class="form-control" name="Clave" id="Clave" title="LA CONTRASEÑA ES IGUAL AL NUMERO DE DOCUMENTO" required readonly>
        </div>
        <div class="col-md-6">
          <label for="fecha_baja" class="form-label">Fecha Expiración</label>
          <input type="date" class="form-control" name="Fecha_baja" id="Fecha_baja" required>
        </div>
        <div class="col-6 text-center mb-5 mt-5">
          <button type="submit" class="btn btn-success-strong border border-1 border-black">Guardar</button>
          <input type="hidden" name="unidadesData" id="unidadesData">
        </div>
        <div class="col-6 text-center mb-5 mt-5">
          <a href="/usuarios" class="btn btn-danger-strong border border-1 border-black">Cancelar</a>
        </div>
      </form>
</div>



<%- include('partials/_footer') %>

<script>
  (function(){
    try{
      var fechaInput = document.getElementById('Fecha_baja');
      if(fechaInput && !fechaInput.value){
        var d = new Date();
        d.setFullYear(d.getFullYear() + 1);
        var iso = d.toISOString().split('T')[0];
        fechaInput.value = iso;
        // opcional: evitar seleccionar una fecha anterior a hoy
        fechaInput.min = new Date().toISOString().split('T')[0];
      }
    }catch(err){
      console.error('Set default Fecha_baja error', err);
    }
  })();
</script>