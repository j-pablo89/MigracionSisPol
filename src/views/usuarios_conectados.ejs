<%- include('partials/_header2') %>

<div class="container-fluid mainSection" id="main-container" data-page="usuarios_conectados">
    <div class="container mt-5 mb-3">
        <h3 class="text-white text-center text-borderWhite">CONEXIONES USUARIOS</h3>
    </div>
    <div class="table-responsive mt-5" style="overflow-x:auto; max-height: 600px;"> 
        <table class="table table-bordered table-striped align-middle tabla-movimientos">
            <thead class="table-primary text-center" style="position: sticky;">
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-usuario">Usuario</th>
                    <th class="col-dep">Dependencia</th>
                    <th class="col-nombre">Apellido y Nombre</th>
                    <th class="col-doc">Nro Documento</th>
                    <th class="col-horaConexion">Hora Conexion</th>
                    <th class="col-tipoConexion">Tipo</th>
                    <th class="col-tipouser">Perfil</th>
                </tr>
            </thead>
            <tbody>
                <%if (usuarios && usuarios.length > 0) {%>
                    <%j = 1%>
                    <% usuarios.forEach( usuario => { %>
                    <tr>
                        <td class="text-center"><%=j%></td>
                        <td><%=usuario.Usuario%></td>
                        <td><%=usuario.Detalle%></td>
                        <td><%=usuario.Apellido%>, <%=usuario.Nombre%></td>
                        <td><%=usuario.Dni%></td>
                        <td><%=usuario.FechaHoraSesion%></td>
                        <td><%=usuario.Tipo%></td>
                        <td><%=usuario.Rol%></td>
                    </tr>
                    <%j = j + 1%>
                    <%})%>
                <%}%>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/_footer') %>