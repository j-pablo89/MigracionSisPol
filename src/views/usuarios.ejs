<%- include('partials/_header2') %>


<div id="main-container" class="mainSection" data-page="listar_usuarios">
    <div class="mainSection mb-5 ">
        <div class="container mt-5 mb-4">
            <div id="message-container" 
                data-success="<%= success_msg || '' %>" 
                data-error="<%= error_msg || '' %>">
            </div>
            <h3 class="text-white text-center text-borderWhite">USUARIOS</h3>
        </div>
        <div> 
            <div class="row mb-3">
                <div class="col-md-4 col-6 mb-2">
                     <label class="text-white d-none d-md-block form-label">Buscar usuarios:</label>
                     <label class="text-white d-block d-md-none form-label">Buscar usuarios:</label>
                     <input type="text" id="filtroBusqueda" class="form-control">
                </div>
            </div>
            <div class="table-responsive d-none d-md-block">
                <table class="table table-hover" id="tablaUsuarios">
                    <thead>
                        <tr class="table-primary">
                            <th scope="col">ID</th>
                            <th scope="col">Usuario/DNI</th>
                            <th scope="col">Perfil</th>
                            <th scope="col">Permisos</th>
                            <th scope="col">Apellido</th>
                            <th scope="col">Nombre</th>
                            <th scope="col">Estado</th>
                            <th scope="col" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                   <tbody class="centrar-botones">
                    <% if (usuarios && usuarios.length > 0) { %>
                    <% let j = 1;%>
                    <% usuarios.forEach(usuario => { %>
                        <%
                        const rol = usuario.nombre_rol;
                        const rolViewer = session.nombre_rol;
                        const esAdmin = rol === 'ADMINISTRADOR';
                        const esSuperAdmin = rol === 'SUPERADMIN';
                        const esUsuarioComun = ['USUARIO', 'USUARIO GENERAL', 'SIN PERFIL'].includes(rol);
                        const claseFila =  esSuperAdmin ? 'table-superadmin' : esAdmin ? 'table-bordo' : '';
                        let mostrarBotones = false;
                        if (rolViewer === 'SUPERADMIN') {
                            mostrarBotones = !esSuperAdmin;
                        } else if (rolViewer === 'ADMINISTRADOR') {
                            mostrarBotones = esUsuarioComun;
                        }
                        %>
                        <tr class="<%= claseFila %> usuario-fila" data-busqueda="<%= [usuario.Usuario, usuario.Dni, usuario.Permiso, usuario.Apellido, usuario.Nombre, usuario.nombre_rol, usuario.Estado === 1 ? 'activo' : 'inactivo'].join(' ') %>" style="height: 50px;">
                        <td class="align-middle"><%= j++ %></td>
                        <td class="align-middle"><%= usuario.Usuario %></td>
                        <td class="align-middle"><%= usuario.nombre_rol %></td>
                        <td class="align-middle"><%= usuario.Permiso %></td>
                        <td class="align-middle"><%= usuario.Apellido %></td>
                        <td class="align-middle"><%= usuario.Nombre %></td>
                        <td class="align-middle"><%= usuario.Estado === 1 ? 'Activo' : 'Inactivo' %></td>
                        <td class="centrar-td d-flex justify-content-around" style="height: 55px;">
                            <% if (usuario.Estado === 0) { %>
                                <form action="/reactivar_usuario/<%= usuario.id_usuario %>" method="POST">
                                    <button class="btn btn-outline-success btn-sm">ACTIVAR</button>
                                </form>
                            <% } else if (mostrarBotones) { %>
                                <form class="formResetClave" action="/usuarios" method="POST">
                                    <input type="hidden" name="id_usuario" value="<%= usuario.id_usuario %>">
                                    <input type="hidden" name="Dni" value="<%= usuario.Dni %>">
                                    <button class="btn btn-outline-info btn-sm">RESET CLAVE</button>
                                </form>
                                <a class="btn btn-outline-success btn-sm"
                                    href="/modificar_usuario/<%= usuario.id_usuario %>">
                                    MODIFICAR
                                </a>
                                <a class="btn btn-outline-danger btn-sm"
                                    href="/acceso_usuario/<%= usuario.id_usuario %>">
                                    ACCESO
                                </a>
                            <% } %>
                        </td>
                        </tr>
                    <% }) %>
                    <% } else { %>
                    <tr>
                        <td colspan="8" class="text-center">No hay usuarios</td>
                    </tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
            <div id="listaUsuariosMobile" class="d-block d-md-none">
            <% if (usuarios) { %>
                <% for (let usuario of usuarios) { %>
                    <%
                    const rol = usuario.nombre_rol;
                    const rolViewer = session.nombre_rol;
                    const esAdmin = rol === 'ADMINISTRADOR';
                    const esSuperAdmin = rol === 'SUPERADMIN';
                    const claseFila =  esSuperAdmin ? 'bg-superadmin' : esAdmin ? 'bg-bordo' : '';
                    let mostrarBotones = false;
                    if (rolViewer === 'SUPERADMIN') {
                        mostrarBotones = !esSuperAdmin;
                    } else if (rolViewer === 'ADMINISTRADOR') {
                        mostrarBotones = esUsuarioComun;
                    }
                    %>
                    <div class="card mb-3 shadow-sm usuario-card <%= claseFila %>" data-busqueda="<%= [usuario.Usuario, usuario.Dni, usuario.Permiso, usuario.Apellido, usuario.Nombre, usuario.nombre_rol, usuario.Estado === 1 ? 'activo' : 'inactivo'].join(' ') %>">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <img src="<%= usuario.Avatar_url %>" alt="" class="rounded me-3" style="width: 40px; height: 40px;">
                                <h5 class="mb-0"><%= usuario.Apellido %> <%= usuario.Nombre %></h5>
                            </div>
                            <p class="mb-1"><strong>Usuario:</strong> <%= usuario.Usuario %></p>
                            <p class="mb-1"><strong>Tipo perfil:</strong> <%= usuario.nombre_rol %></p>
                            <p class="mb-1"><strong>Estado:</strong> <%= usuario.Estado === 1 ? 'Activo' : 'Inactivo' %></p>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <% if (usuario.Estado === 0) { %>
                                    <form action="/reactivar_usuario/<%= usuario.id_usuario %>" method="POST" style="display:inline;">
                                        <button class="btn btn-outline-success btn-sm" type="submit">ACTIVAR</button>
                                    </form>
                                <% } else if (mostrarBotones) { %>
                                    <form class="formResetClave" action="/usuarios" method="POST" style="display:inline;">
                                        <input type="hidden" name="id_usuario" value="<%= usuario.id_usuario %>">
                                        <input type="hidden" name="Dni" value="<%= usuario.Dni %>">
                                        <button class="btn btn-outline-info btn-sm" type="submit">RESET CLAVE</button>
                                    </form>
                                    <a class="btn btn-outline-success btn-sm" href="/modificar_usuario/<%= usuario.id_usuario%>">MODIFICAR</a>
                                    <a class="btn btn-outline-danger btn-sm" href="/acceso_usuario/<%= usuario.id_usuario%>">ACCESO</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            <% } %>
                <div id="sinResultadosMobile" class="text-white text-center py-3 d-none">No se encontraron usuarios</div>
            </div>
        </div>
    </div>
</div>

  <script>
    function cargarModalAcceso(id, perfil) {
        document.getElementById("modal_id_usuario").value = id;
    }

    document.addEventListener("DOMContentLoaded", function () {

        const filtroInput = document.getElementById("filtroBusqueda");
        if (!filtroInput) return;

        const cardsMovil = document.querySelectorAll(".usuario-card");
        const sinResultadosMobile = document.getElementById("sinResultadosMobile");

        function normalizar(texto) {
            return (texto || "")
                .toString()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .toLowerCase()
                .trim();
        }

        function aplicarFiltroCards() {

            const filtro = normalizar(filtroInput.value);
            let visibles = 0;

            cardsMovil.forEach((card) => {

                const textoBusqueda = normalizar(card.dataset.busqueda);

                const coincide = textoBusqueda.includes(filtro);

                card.style.display = coincide ? "" : "none";

                if (coincide) visibles++;
            });

            if (sinResultadosMobile) {
                sinResultadosMobile.classList.toggle("d-none", visibles > 0);
            }
        }

        filtroInput.addEventListener("input", aplicarFiltroCards);

    });
</script>


<%- include('partials/_footer') %>