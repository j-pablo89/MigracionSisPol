<%- include('partials/_header2') %>

<% function renderDetalleValor(valor) {
  if (valor === null || valor === undefined) return '';
  if (typeof valor === 'string') {
    try {
      return renderDetalleValor(JSON.parse(valor));
    } catch (error) {
      return valor;
    }
  }
  if (Array.isArray(valor)) {
    return valor.map(item => `<div>${renderDetalleValor(item)}</div>`).join('');
  }
  if (typeof valor === 'object') {
    return Object.entries(valor).map(([clave, valorActual]) => {
      const valorFormateado = typeof valorActual === 'object' && valorActual !== null ? renderDetalleValor(valorActual) : valorActual;
      return `<div><strong>${clave}:</strong> ${valorFormateado}</div>`;
    }).join('');
  }
  return String(valor);
} %>

<div class="container-fluid mainSection" id="main-container" data-page="movimientos_comisarias">
    <div class="container mt-5 mb-3">
        <h3 class="text-white text-center text-borderWhite">MOVIMIENTOS COMISARIAS</h3>
    </div>
    <div class="mb-3">
        <div class="col-md-4 col-6 mb-2">
            <label class="text-white d-none d-md-block form-label">Buscar:</label>
            <label class="text-white d-block d-md-none form-label">Buscar:</label>
            <input type="text" id="filtroBusqueda" class="form-control">
        </div>
    </div>
    <div class="table-responsive mt-5" style="overflow-x: auto; height: 400px;" id="tablaMovimientos"> 
        <table class="table table-bordered table-striped align-middle tabla-movimientos">
            <thead class="table-primary">
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-nombre">Apellido y Nombre</th>
                    <th class="col-doc">Nro Documento</th>
                    <th class="col-aloj">Detalle Alojamiento</th>
                    <th class="col-dest">Destino Traslado</th>
                    <th class="col-fecha">Fecha Movimiento</th>
                    <th class="col-tipo">Tipo Movimiento</th>
                    <th class="col-user">Usuario Carga</th>
                    <th class="col-obs">Observaciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (movimientos && movimientos.length > 0) {  %>
                    <% j = 1 %>
                  <% movimientos.forEach(movimiento => { %>
                    <tr>
                      <td><%= j %></td>
                      <td><%= movimiento.Apellido %> <%= movimiento.Nombre %></td>
                      <td><%= movimiento.Dni %></td>
                      <td><%= movimiento.Detalle_Alojado %></td>
                      <td><%= movimiento.Detalle_Destino %></td>
                      <td><%= movimiento.Fecha_movimiento %></td>
                      <td><%= movimiento.Tipo_movimiento %></td>
                      <td><%= movimiento.Usuario %></td>
                      <td class="text-wrap">
                        <% if (movimiento.Detalle) { %>
                          <%- renderDetalleValor(movimiento.Detalle) %>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                    </tr>
                    <% j = j + 1%>
                  <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>
    <div class="text-center mt-4">
        <a href="/movimientos_comisarias/exportar" class="btn btn-success-strong text-center">
            <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
        </a>
    </div>
    
</div>

<%- include('partials/_footer') %>